<view class="page">
  <view class="card">
    <view class="row">
      <text class="card-title">近 7 天净摄入</text>
      <text class="pill blue">{{averageText}}</text>
    </view>
    <view class="bars">
      <view class="bar-col" wx:for="{{bars}}" wx:key="day">
        <view class="bar {{item.active ? 'active' : ''}}" style="height: {{item.height}}rpx;"></view>
        <text>{{item.day}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <text class="card-title">每日摘要</text>
    <view class="record row" wx:for="{{days}}" wx:key="date">
      <view>
        <view class="record-title">{{item.date}}</view>
        <view class="muted small">{{item.net}}</view>
      </view>
      <text class="strong {{item.warning ? 'red-text' : 'green-text'}}">{{item.delta}}</text>
    </view>
  </view>
</view>
