<view class="page">
  <view class="card">
    <view class="row">
      <text class="card-title">{{dateTitle}}</text>
      <text class="pill blue">{{goalLabel}}</text>
    </view>
    <view class="summary">
      <view class="ring">
        <text class="ring-number">{{netCalories}}</text>
        <text class="ring-label">kcal 净摄入</text>
      </view>
      <view class="stat-list">
        <!-- 推荐摄入来自用户信息模块计算结果。 -->
        <view class="row"><text class="muted">推荐摄入</text><text class="strong">{{targetCalories}} kcal</text></view>
        <view class="row"><text class="muted">摄入</text><text class="strong">{{foodCalories}} kcal</text></view>
        <view class="row"><text class="muted">运动</text><text class="strong blue-text">-{{exerciseCalories}} kcal</text></view>
        <view class="row"><text class="muted">剩余预算</text><text class="strong">{{remainingCalories}} kcal</text></view>
      </view>
    </view>
  </view>

  <view class="card">
    <text class="card-title">营养素进度</text>
    <view class="macro" wx:for="{{macros}}" wx:key="name">
      <view class="row"><text>{{item.name}}</text><text class="value">{{item.value}}</text></view>
      <view class="track"><view class="fill {{item.color}}" style="width: {{item.percent}}%;"></view></view>
    </view>
  </view>

  <view class="actions">
    <button class="button" bindtap="goEntry">记录饮食</button>
    <button class="button secondary" bindtap="goEntry">记录运动</button>
  </view>

  <view class="card">
    <text class="card-title">今日记录</text>
    <view wx:if="{{loadingRecords}}" class="muted small">正在读取今日记录...</view>
    <view wx:elif="{{!records.length}}" class="muted small">还没有记录，去写下今天吃了什么或做了什么运动。</view>
    <view class="record row" wx:for="{{records}}" wx:key="id">
      <view class="record-content">
        <view class="record-title">{{item.title}}</view>
        <view class="muted small">{{item.desc}}</view>
      </view>
      <view class="record-actions">
        <text class="strong {{item.type === 'exercise' ? 'blue-text' : ''}}">{{item.calories}}</text>
        <button
          class="delete-button {{deletingId ? 'delete-button-disabled' : ''}}"
          loading="{{deletingId === item.id}}"
          disabled="{{!!deletingId}}"
          data-item-type="{{item.itemType}}"
          data-item-id="{{item.id}}"
          data-title="{{item.title}}"
          bindtap="deleteDailyItem"
        >删除</button>
      </view>
    </view>
  </view>

  <view class="input-dock">
    <textarea
      class="daily-input"
      value="{{dailyInput}}"
      placeholder="例如：早上吃了一个鸡蛋和一杯牛奶，晚上跑步30分钟"
      maxlength="500"
      auto-height
      bindinput="onDailyInput"
    />
    <button class="parse-button" loading="{{parsing}}" disabled="{{parsing}}" bindtap="parseDailyInput">AI解析</button>
  </view>
</view>
