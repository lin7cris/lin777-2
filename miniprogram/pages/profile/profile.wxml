<view class="page">
  <!-- 用户资料摘要，保存成功后会展示最新计算结果。 -->
  <view class="card profile-card">
    <view class="avatar">热</view>
    <view>
      <view class="card-title">AI热量记录助手用户</view>
      <view class="copy">{{genderText}} · {{profile.age}} 岁 · {{profile.height}}cm · {{profile.weight}}kg</view>
    </view>
  </view>

  <!-- 用户基础信息表单，所有字段都会保存到 users 云数据库集合。 -->
  <view class="card">
    <text class="card-title">基础信息</text>

    <view class="row field">
      <text>性别</text>
      <picker class="picker-value" range="{{genderOptions}}" range-key="label" value="{{genderIndex}}" data-field="gender" bindchange="onPickerChange">
        <text>{{genderOptions[genderIndex].label}}</text>
      </picker>
    </view>

    <view class="row field">
      <text>年龄</text>
      <input class="input-value" type="number" value="{{form.age}}" data-field="age" bindinput="onNumberInput" />
    </view>

    <view class="row field">
      <text>身高 cm</text>
      <input class="input-value" type="digit" value="{{form.height}}" data-field="height" bindinput="onNumberInput" />
    </view>

    <view class="row field">
      <text>当前体重 kg</text>
      <input class="input-value" type="digit" value="{{form.weight}}" data-field="weight" bindinput="onNumberInput" />
    </view>

    <view class="row field">
      <text>目标体重 kg</text>
      <input class="input-value" type="digit" value="{{form.targetWeight}}" data-field="targetWeight" bindinput="onNumberInput" />
    </view>

    <view class="row field">
      <text>活动强度</text>
      <picker class="picker-value" range="{{activityOptions}}" range-key="label" value="{{activityIndex}}" data-field="activityLevel" bindchange="onPickerChange">
        <text>{{activityOptions[activityIndex].label}}</text>
      </picker>
    </view>

    <view class="row field">
      <text>目标</text>
      <picker class="picker-value" range="{{goalOptions}}" range-key="label" value="{{goalIndex}}" data-field="goal" bindchange="onPickerChange">
        <text>{{goalOptions[goalIndex].label}}</text>
      </picker>
    </view>

    <button class="button" loading="{{saving}}" bindtap="saveProfile">保存用户信息</button>
  </view>

  <!-- 推荐结果由 utils/calorie.js 根据表单信息实时保存时计算。 -->
  <view class="card">
    <text class="card-title">目标与推荐</text>
    <view class="row field"><text>BMR</text><text class="value">{{profile.bmr}} kcal</text></view>
    <view class="row field"><text>TDEE</text><text class="value">{{profile.tdee}} kcal</text></view>
    <view class="row field"><text>推荐摄入</text><text class="value">{{profile.targetCalories}} kcal</text></view>
    <view class="row field"><text>蛋白质范围</text><text class="value">{{profile.macros.protein}}</text></view>
    <view class="row field"><text>碳水范围</text><text class="value">{{profile.macros.carbs}}</text></view>
    <view class="row field"><text>脂肪范围</text><text class="value">{{profile.macros.fat}}</text></view>
  </view>

  <!-- 后续 AI 和数据能力入口，目前先作为设置占位。 -->
  <view class="card">
    <text class="card-title">数据与 AI</text>
    <view class="row field" wx:for="{{options}}" wx:key="name">
      <text>{{item.name}}</text>
      <text class="value">›</text>
    </view>
  </view>
</view>
