.parse-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf2ee;
}

.parse-item:last-child {
  border-bottom: 0;
}

.item-title {
  font-weight: 700;
}

.small {
  margin-top: 6rpx;
  font-size: 24rpx;
}

.strong {
  font-weight: 800;
  white-space: nowrap;
}

.blue-text {
  color: #356be6;
}

.source-text {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  background: #f3f7f1;
  color: #3a473f;
  font-size: 26rpx;
  line-height: 1.5;
}

.edit-grid {
  display: grid;
  gap: 16rpx;
  margin-top: 16rpx;
}

.edit-grid.two {
  grid-template-columns: 1fr 1fr;
}

.edit-grid.four {
  grid-template-columns: repeat(4, 1fr);
}

.edit-field {
  min-width: 0;
}

.edit-label {
  display: block;
  margin-bottom: 8rpx;
  color: #6d7a72;
  font-size: 22rpx;
}

.edit-input {
  width: 100%;
  height: 68rpx;
  padding: 0 14rpx;
  border-radius: 12rpx;
  background: #f3f7f1;
  color: #142018;
  font-size: 26rpx;
  box-sizing: border-box;
}
