<view class="page">
  <view class="card">
    <view class="row">
      <text class="card-title">AI 已识别 {{foods.length}} 个饮食条目</text>
      <text class="pill">置信度 {{confidenceText}}</text>
    </view>
    <view class="copy">请确认份量，系统会按你的身体信息估算运动消耗。</view>
    <view wx:if="{{sourceText}}" class="source-text">{{sourceText}}</view>
  </view>

  <view class="card">
    <text class="card-title">饮食摄入</text>
    <view wx:if="{{!foods.length}}" class="muted small">没有识别到饮食内容。</view>
    <view class="parse-item" wx:for="{{foods}}" wx:key="index">
      <view class="edit-grid two">
        <view class="edit-field">
          <text class="edit-label">名称</text>
          <input class="edit-input" value="{{item.name}}" data-index="{{index}}" data-field="name" bindinput="onFoodInput" />
        </view>
        <view class="edit-field">
          <text class="edit-label">份量</text>
          <input class="edit-input" value="{{item.amount}}" data-index="{{index}}" data-field="amount" bindinput="onFoodInput" />
        </view>
      </view>
      <view class="edit-grid four">
        <view class="edit-field">
          <text class="edit-label">kcal</text>
          <input class="edit-input" type="number" value="{{item.calories}}" data-index="{{index}}" data-field="calories" bindinput="onFoodInput" />
        </view>
        <view class="edit-field">
          <text class="edit-label">P</text>
          <input class="edit-input" type="digit" value="{{item.protein}}" data-index="{{index}}" data-field="protein" bindinput="onFoodInput" />
        </view>
        <view class="edit-field">
          <text class="edit-label">C</text>
          <input class="edit-input" type="digit" value="{{item.carbs}}" data-index="{{index}}" data-field="carbs" bindinput="onFoodInput" />
        </view>
        <view class="edit-field">
          <text class="edit-label">F</text>
          <input class="edit-input" type="digit" value="{{item.fat}}" data-index="{{index}}" data-field="fat" bindinput="onFoodInput" />
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <text class="card-title">运动消耗</text>
    <view wx:if="{{!exercises.length}}" class="muted small">没有识别到运动内容。</view>
    <view class="parse-item" wx:for="{{exercises}}" wx:key="index">
      <view class="edit-grid two">
        <view class="edit-field">
          <text class="edit-label">名称</text>
          <input class="edit-input" value="{{item.name}}" data-index="{{index}}" data-field="name" bindinput="onExerciseInput" />
        </view>
        <view class="edit-field">
          <text class="edit-label">强度</text>
          <input class="edit-input" value="{{item.intensity}}" data-index="{{index}}" data-field="intensity" bindinput="onExerciseInput" />
        </view>
      </view>
      <view class="edit-grid two">
        <view class="edit-field">
          <text class="edit-label">分钟</text>
          <input class="edit-input" type="number" value="{{item.duration}}" data-index="{{index}}" data-field="duration" bindinput="onExerciseInput" />
        </view>
        <view class="edit-field">
          <text class="edit-label">kcal</text>
          <input class="edit-input" type="number" value="{{item.calories}}" data-index="{{index}}" data-field="calories" bindinput="onExerciseInput" />
        </view>
      </view>
    </view>
  </view>

  <button class="button" bindtap="confirmRecord">确认并写入今日记录</button>
  <button class="button secondary" bindtap="adjustRecord">调整份量</button>
</view>
